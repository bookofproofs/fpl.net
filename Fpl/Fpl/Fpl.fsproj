        <Compile Include="Interpreter\SymbolTable\Evaluation\FplInterpreter.Globals.State.fs" />
        <Compile Include="Interpreter\SymbolTable\Evaluation\FplInterpreter.Globals.Validity.fs" />
        <Compile Include="Interpreter\SymbolTable\Evaluation\FplInterpreter.Globals.Heap.fs" />
