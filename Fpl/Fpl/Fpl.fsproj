        <Compile Include="Interpreter\SymbolTable\Types2\CompoundPredicates.fs" />
        <Compile Include="Interpreter\SymbolTable\Types2\Variables.fs" />
        <Compile Include="Interpreter\SymbolTable\Types2\References.fs" />
        <Compile Include="Interpreter\SymbolTable\Types2\Definitions.fs" />
        <Compile Include="Interpreter\SymbolTable\TypeMatching\TypeMatching.fs" />
