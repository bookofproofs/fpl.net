        <Compile Include="Parser\Formatting.fs" />
        <Compile Include="Parser\Main.fs" />
        <None Include="Interpreter\DocuSymbolTable.md" />
        <Compile Include="Interpreter\BasicTypes.fs" />
        <Compile Include="Interpreter\Helpers\Checks.fs" />
        <Compile Include="Interpreter\Helpers\Basic.fs" />
