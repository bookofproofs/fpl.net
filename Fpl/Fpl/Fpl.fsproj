<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net8.0</TargetFramework>
        <GenerateProgramFile>false</GenerateProgramFile>
        <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
        <PublishSingleFile>true</PublishSingleFile>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="FplPrivimitives.fs" />
        <Compile Include="FplGrammarTypes.fs" />
        <Compile Include="ErrDiagnostics.fs" />
        <Compile Include="FplInterpreterDiagnosticsEmitter.fs" />
        <None Include="CHANGES.md" />
        <None Include="DocuSymbolTable.md" />
        <None Include="DocuFplGrammarPocShiftFromPythonToFSharp.md" />
        <Compile Include="FplParser.fs" />
        <Compile Include="FplInterpreterAstPreprocessing.fs" />
        <Compile Include="FplInterpreterBasicTypes.fs" />
        <Compile Include="FplInterpreter.Globals.Debug.fs" />
        <Compile Include="FplInterpreter.Globals.Main.fs" />
        <Compile Include="FplInterpreterChecks.fs" />
        <Compile Include="FplInterpreterST.fs" />
        <Compile Include="FplInterpreterSTEmbedding.fs" />
        <Compile Include="FplInterpreterIntrinsicTypes.fs" />
        <Compile Include="FplInterpreterVariables.fs" />
        <Compile Include="FplInterpreterReferences.fs" />
        <Compile Include="FplInterpreterDefinitions.fs" />
        <Compile Include="FplInterpreterFplTypeMatching.fs" />
        <Compile Include="FplInterpreterReferencesSelfParent.fs" />
        <Compile Include="FplInterpreterPredicativeBlocks.fs" />
        <Compile Include="FplInterpreterDefinitionProperties.fs" />
        <Compile Include="FplInterpreterProofs.fs" />
        <Compile Include="FplInterpreterQuantors.fs" />
        <Compile Include="FplInterpreterCompoundPredicates.fs" />
        <Compile Include="FplInterpreterRulesOfInferences.fs" />
        <Compile Include="FplInterpreterMapCases.fs" />
        <Compile Include="FplInterpreterExtensions.fs" />
        <Compile Include="FplInterpreterDelegates.fs" />
        <Compile Include="FplInterpreterLocalization.fs" />
        <Compile Include="FplInterpreterAssertStmt.fs" />
        <Compile Include="FplInterpreterCasesStmt.fs" />
        <Compile Include="FplInterpreterAssigments.fs" />
        <Compile Include="FplInterpreterIsOperator.fs" />
        <Compile Include="FplInterpreterForStmt.fs" />
        <Compile Include="FplInterpreterUsesClause.fs" />
        <Compile Include="FplInterpreterBuildingBlocks.fs" />
        <Compile Include="FplInterpreter.Main.fs" />
        <Compile Include="Program.fs" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="FParsec" Version="1.1.1" />
        <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\TestSharedConfig\TestSharedConfig.fsproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Update="FSharp.Core" Version="9.0.303" />
    </ItemGroup>

</Project>
